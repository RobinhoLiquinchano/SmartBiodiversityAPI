@* =====================================================================
   PANEL LATERAL COMPARTIDO (Administración)
   - Idéntico en TODAS las vistas (se inyecta con: @await Html.PartialAsync("_AdminSidebar"))
   - FIJO: no se mueve al hacer scroll (position: fixed).
   - El ítem activo se calcula solo según la acción actual.
   - "Taxonomía" fue reemplazado por "Avisos".
   ===================================================================== *@
@{
    var __sbAct = (ViewContext.RouteData.Values["action"] ?? string.Empty).ToString();
}

<style>
    /* box-sizing global: evita que el panel fijo (width+padding) se solape con el contenido.
           Es inofensivo en vistas que ya lo tengan y arregla las que no (p.ej. Avisos). */
    *, *::before, *::after {
        box-sizing: border-box;
    }

    /* === Estilos visuales del panel (auto-contenidos: colores fijos, no dependen del :root de la vista) === */
    .sidebar {
        background: #162232;
        color: #fff;
        padding: 24px 16px;
        display: flex;
        flex-direction: column;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 40px;
    }

    .logo-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: #22c55e;
        display: grid;
        place-items: center;
        font-size: 22px;
    }

    .logo-text {
        font-weight: bold;
        line-height: 1.1;
    }

        .logo-text span {
            color: #22c55e;
            display: block;
        }

    .menu-title {
        font-size: 12px;
        color: #94a3b8;
        margin: 0 0 12px 8px;
        letter-spacing: 1px;
    }

    .menu {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 10px;
        color: #cbd5e1;
        text-decoration: none;
        font-size: 15px;
    }

        .menu-item:hover {
            background: #223044;
        }

        .menu-item.active {
            background: rgba(34, 197, 94, 0.15);
            color: #22c55e;
            font-weight: bold;
            border-right: 4px solid #22c55e;
        }

    .profile {
        margin-top: auto;
        background: #223044;
        border-radius: 14px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #6366f1;
        display: grid;
        place-items: center;
        font-weight: bold;
    }

    .profile-info strong {
        display: block;
        font-size: 15px;
    }

    .profile-info span {
        color: #94a3b8;
        font-size: 13px;
    }

    /* === Carcasa del panel: FIJA e idéntica (sobreescribe el grid de cada vista) === */
    .dashboard {
        display: block !important;
    }

    aside.sidebar {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 260px !important;
        height: 100vh !important;
        overflow-y: auto !important;
        z-index: 50 !important;
    }

    .main {
        margin-left: 260px !important;
        width: auto !important;
    }

    @@media (max-width: 900px) {
        aside.sidebar {
            display: none !important;
        }

        .main {
            margin-left: 0 !important;
        }
    }
</style>

<aside class="sidebar">
    <div class="logo">
        <div class="logo-icon">🌱</div>
        <div class="logo-text">Smart <span>Biodiversity</span></div>
    </div>

    <p class="menu-title">MENÚ</p>

    <nav class="menu">
        <a asp-controller="Administracion" asp-action="Index"
           class="menu-item @(__sbAct == "Index" ? "active" : "")">▦ Dashboard</a>

        <a asp-controller="Administracion" asp-action="InventarioEspecies"
           class="menu-item @(__sbAct == "InventarioEspecies" || __sbAct == "Fauna" || __sbAct == "Flora" ? "active" : "")">🌿 Inventario Especies</a>

        <a asp-controller="Administracion" asp-action="Avisos"
           class="menu-item @(__sbAct == "Avisos" ? "active" : "")">📢 Avisos</a>

        <a href="#" class="menu-item">🗺️ Mapa Campus</a>

        <a href="#" class="menu-item">✅ Validaciones</a>

        <a asp-controller="Administracion" asp-action="Usuarios"
           class="menu-item @(__sbAct == "Usuarios" ? "active" : "")">👥 Usuarios</a>

        <a asp-controller="Administracion" asp-action="Reportes"
           class="menu-item @(__sbAct == "Reportes" ? "active" : "")">📊 Reportes</a>

        <a href="#" class="menu-item">⚙️ Configuración</a>
    </nav>

    <div class="profile">
        <div class="avatar">A</div>
        <div class="profile-info">
            <strong>Perfil</strong>
            <span>Administrador Principal</span>
        </div>
    </div>
</aside>
