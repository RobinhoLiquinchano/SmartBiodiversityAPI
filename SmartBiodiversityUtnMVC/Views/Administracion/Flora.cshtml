@model IEnumerable<SmartBiodiversityUtnModels.DTOs.Especie.EspecieResponse>

@{
    Layout = null;
    ViewData["Title"] = "Inventario de Flora";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inventario de Flora - Smart Biodiversity</title>

    <style>
            :root {
                --bg: #f4f6fa;
                --sidebar: #162232;
                --sidebar-light: #223044;
                --primary: #22c55e;
                --text: #111827;
                --muted: #6b7280;
                --card: #ffffff;
                --border: #e5e7eb;
                --radius: 16px;
                --shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                background: var(--bg);
                color: var(--text);
            }

            .dashboard {
                display: grid;
                grid-template-columns: 260px 1fr;
                min-height: 100vh;
            }

            .sidebar {
                background: var(--sidebar);
                color: white;
                padding: 24px 16px;
                display: flex;
                flex-direction: column;
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 40px;
            }

            .logo-icon {
                width: 42px;
                height: 42px;
                border-radius: 10px;
                background: var(--primary);
                display: grid;
                place-items: center;
                font-size: 22px;
            }

            .logo-text {
                font-weight: bold;
                line-height: 1.1;
            }

                .logo-text span {
                    color: var(--primary);
                    display: block;
                }

            .menu-title {
                font-size: 12px;
                color: #94a3b8;
                margin: 0 0 12px 8px;
                letter-spacing: 1px;
            }

            .menu {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            .menu-item {
                display: block;
                padding: 14px 16px;
                border-radius: 10px;
                color: #cbd5e1;
                text-decoration: none;
                font-size: 15px;
            }

                .menu-item:hover {
                    background: var(--sidebar-light);
                }

                .menu-item.active {
                    background: rgba(34, 197, 94, 0.15);
                    color: var(--primary);
                    font-weight: bold;
                    border-right: 4px solid var(--primary);
                }

            .profile {
                margin-top: auto;
                background: var(--sidebar-light);
                border-radius: 14px;
                padding: 16px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .avatar {
                width: 42px;
                height: 42px;
                border-radius: 50%;
                background: #6366f1;
                display: grid;
                place-items: center;
                font-weight: bold;
            }

            .profile-info strong {
                display: block;
                font-size: 15px;
            }

            .profile-info span {
                color: #94a3b8;
                font-size: 13px;
            }

            .main {
                display: flex;
                flex-direction: column;
            }

            .topbar {
                height: 72px;
                padding: 0 28px;
                background: white;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .topbar-brand {
                font-size: 20px;
                font-weight: bold;
            }

            .back-button {
                background: #ecfdf5;
                color: #15803d;
                text-decoration: none;
                border-radius: 10px;
                padding: 10px 16px;
                font-weight: bold;
            }

            .content {
                padding: 32px;
            }

            .page-title h1 {
                margin: 0;
                font-size: 30px;
            }

            .page-title p {
                color: var(--muted);
                margin: 8px 0 28px;
            }

            .species-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
                gap: 22px;
            }

            .species-card {
                background: var(--card);
                padding: 22px;
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                border-top: 5px solid #22c55e;
            }

            .species-icon {
                font-size: 38px;
                margin-bottom: 12px;
            }

            .species-card h2 {
                font-size: 21px;
                margin: 0 0 6px;
            }

            .scientific-name {
                color: #15803d;
                font-style: italic;
                margin-bottom: 16px;
            }

            .species-info {
                color: var(--muted);
                line-height: 1.5;
                font-size: 14px;
            }

            .category-badge {
                display: inline-block;
                margin-top: 16px;
                background: #dcfce7;
                color: #15803d;
                border-radius: 999px;
                padding: 6px 12px;
                font-size: 13px;
                font-weight: bold;
            }

            .empty-state {
                background: white;
                padding: 42px;
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                text-align: center;
                color: var(--muted);
            }

            @@media (max-width: 900px) {
                .dashboard {
                    grid-template-columns: 1fr;
                }

                .sidebar {
                    display: none;
                }

                .content {
                    padding: 24px 16px;
                }
            }
    </style>
</head>

<body>
    <div class="dashboard">

        <aside class="sidebar">
            <div class="logo">
                <div class="logo-icon">🌱</div>
                <div class="logo-text">Smart <span>Biodiversity</span></div>
            </div>

            <p class="menu-title">MENÚ</p>

            <nav class="menu">
                <a asp-controller="Administracion"
                   asp-action="Index"
                   class="menu-item">
                    ▦ Dashboard
                </a>

                <a asp-controller="Administracion"
                   asp-action="InventarioEspecies"
                   class="menu-item active">
                    🌿 Inventario Especies
                </a>

                <a href="#" class="menu-item">🔬 Taxonomía</a>
                <a href="#" class="menu-item">🗺️ Mapa Campus</a>
                <a href="#" class="menu-item">📊 Reportes</a>
            </nav>

            <div class="profile">
                <div class="avatar">A</div>
                <div class="profile-info">
                    <strong>Perfil</strong>
                    <span>Administrador Principal</span>
                </div>
            </div>
        </aside>

        <main class="main">
            <header class="topbar">
                <div class="topbar-brand">🌱 Smart Biodiversity</div>

                <a asp-controller="Administracion"
                   asp-action="InventarioEspecies"
                   class="back-button">
                    ← Volver al inventario
                </a>
            </header>

            <section class="content">
                <div class="page-title">
                    <h1>🌿 Inventario de Flora</h1>
                    <p>Especies vegetales registradas en el Campus El Olivo.</p>
                </div>

                @if (Model != null && Model.Any())
                {
                    <section class="species-grid">
                        @foreach (var especie in Model)
                        {
                            <article class="species-card">
                                <div class="species-icon">🌱</div>

                                <h2>@especie.NombreComun</h2>

                                <div class="scientific-name">
                                    @especie.NombreCientifico
                                </div>

                                <div class="species-info">
                                    <p>
                                        <strong>Descripción:</strong><br />
                                        @(string.IsNullOrWhiteSpace(especie.Descripcion)
                                            ? "Sin descripción registrada."
                                            : especie.Descripcion)
                                    </p>

                                    <p>
                                        <strong>Hábitat:</strong><br />
                                        @(string.IsNullOrWhiteSpace(especie.Habitat)
                                            ? "No registrado"
                                            : especie.Habitat)
                                    </p>
                                </div>

                                <span class="category-badge">
                                    @especie.NombreCategoria
                                </span>
                            </article>
                        }
                    </section>
                }
                else
                {
                    <div class="empty-state">
                        <h2>🌿 No hay especies de flora registradas</h2>
                        <p>Cuando se registren especies con la categoría “Flora”, aparecerán aquí.</p>
                    </div>
                }
            </section>
        </main>
    </div>
</body>
</html>