@using SmartBiodiversityUtnModels.DTOs
@using SmartBiodiversityUtnModels.DTOs.Especie
@model IEnumerable<SmartBiodiversityUtnModels.DTOs.Especie.EspecieResponse>

@{
    Layout = null;
    ViewData["Title"] = "Inventario de Fauna";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inventario de Fauna - Smart Biodiversity</title>

    <style>
            :root {
                --bg: #f4f6fa;
                --sidebar: #162232;
                --sidebar-light: #223044;
                --primary: #22c55e;
                --blue: #2563eb;
                --text: #111827;
                --muted: #6b7280;
                --card: #ffffff;
                --border: #e5e7eb;
                --radius: 16px;
                --shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                background: var(--bg);
                color: var(--text);
            }

            .dashboard {
                display: grid;
                grid-template-columns: 260px 1fr;
                min-height: 100vh;
            }

            .sidebar {
                background: var(--sidebar);
                color: white;
                padding: 24px 16px;
                display: flex;
                flex-direction: column;
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 40px;
            }

            .logo-icon {
                width: 42px;
                height: 42px;
                border-radius: 10px;
                background: var(--primary);
                display: grid;
                place-items: center;
                font-size: 22px;
            }

            .logo-text {
                font-weight: bold;
                line-height: 1.1;
            }

                .logo-text span {
                    color: var(--primary);
                    display: block;
                }

            .menu-title {
                font-size: 12px;
                color: #94a3b8;
                margin: 0 0 12px 8px;
                letter-spacing: 1px;
            }

            .menu {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            .menu-item {
                display: block;
                padding: 14px 16px;
                border-radius: 10px;
                color: #cbd5e1;
                text-decoration: none;
                font-size: 15px;
            }

                .menu-item:hover {
                    background: var(--sidebar-light);
                }

                .menu-item.active {
                    background: rgba(34, 197, 94, 0.15);
                    color: var(--primary);
                    font-weight: bold;
                    border-right: 4px solid var(--primary);
                }

            .profile {
                margin-top: auto;
                background: var(--sidebar-light);
                border-radius: 14px;
                padding: 16px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .avatar {
                width: 42px;
                height: 42px;
                border-radius: 50%;
                background: #6366f1;
                display: grid;
                place-items: center;
                font-weight: bold;
            }

            .profile-info strong {
                display: block;
                font-size: 15px;
            }

            .profile-info span {
                color: #94a3b8;
                font-size: 13px;
            }

            .main {
                display: flex;
                flex-direction: column;
            }

            .topbar {
                height: 72px;
                padding: 0 28px;
                background: white;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .topbar-brand {
                font-size: 20px;
                font-weight: bold;
            }

            .back-button {
                background: #dbeafe;
                color: #1d4ed8;
                text-decoration: none;
                border-radius: 10px;
                padding: 10px 16px;
                font-weight: bold;
            }

            .content {
                padding: 32px;
            }

            .page-title h1 {
                margin: 0;
                font-size: 30px;
            }

            .page-title p {
                color: var(--muted);
                margin: 8px 0 28px;
            }

            .panel {
                background: var(--card);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                padding: 24px;
                margin-bottom: 26px;
            }

                .panel h2 {
                    margin: 0 0 18px;
                    font-size: 20px;
                }

            .form-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 14px 18px;
            }

                .form-grid label {
                    display: flex;
                    flex-direction: column;
                    font-size: 13px;
                    font-weight: bold;
                    color: #374151;
                    gap: 6px;
                }

                    .form-grid label.full {
                        grid-column: 1 / -1;
                    }

                .form-grid input, .form-grid textarea, .form-grid select {
                    font: inherit;
                    padding: 10px 12px;
                    border: 1px solid var(--border);
                    border-radius: 10px;
                    background: #f9fafb;
                    font-weight: normal;
                }

                    .form-grid input[type="file"] {
                        padding: 8px;
                        background: #fff;
                    }

                    .form-grid input:focus, .form-grid textarea:focus, .form-grid select:focus {
                        outline: none;
                        border-color: var(--primary);
                        background: #fff;
                    }

            .actions {
                display: flex;
                gap: 10px;
                justify-content: flex-end;
                margin-top: 4px;
            }

            .btn {
                border: none;
                cursor: pointer;
                font: inherit;
                font-weight: bold;
                border-radius: 10px;
                padding: 10px 16px;
                text-decoration: none;
                display: inline-block;
            }

            .btn-primary {
                background: var(--primary);
                color: #fff;
            }

                .btn-primary:hover {
                    background: #16a34a;
                }

            .btn-ghost {
                background: #e5e7eb;
                color: #111827;
            }

            .btn-edit {
                background: #dbeafe;
                color: #1d4ed8;
                padding: 7px 12px;
                font-size: 13px;
            }

            .btn-del {
                background: #fee2e2;
                color: #b91c1c;
                padding: 7px 12px;
                font-size: 13px;
            }

            .table-wrap {
                overflow-x: auto;
            }

            .tbl {
                width: 100%;
                border-collapse: collapse;
                font-size: 14px;
            }

                .tbl th, .tbl td {
                    text-align: left;
                    padding: 12px 14px;
                    border-bottom: 1px solid var(--border);
                    vertical-align: middle;
                }

                .tbl thead th {
                    background: #f9fafb;
                    color: #374151;
                    font-size: 12px;
                    text-transform: uppercase;
                    letter-spacing: .5px;
                }

                .tbl tbody tr:hover {
                    background: #f9fafb;
                }

                .tbl td.right, .tbl th.right {
                    text-align: right;
                    white-space: nowrap;
                }

            .badge {
                display: inline-block;
                padding: 4px 10px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: bold;
            }

            .b-ok {
                background: #dcfce7;
                color: #166534;
            }

            .b-off {
                background: #e5e7eb;
                color: #374151;
            }

            .b-rev {
                background: #fef9c3;
                color: #854d0e;
            }

            .alert {
                padding: 14px 18px;
                border-radius: 12px;
                margin-bottom: 20px;
                font-weight: bold;
            }

            .alert-ok {
                background: #dcfce7;
                color: #166534;
                border: 1px solid #86efac;
            }

            .alert-err {
                background: #fee2e2;
                color: #991b1b;
                border: 1px solid #fca5a5;
            }

            .warn {
                color: #92400e;
                background: #fef9c3;
                border: 1px solid #fde68a;
                padding: 12px 14px;
                border-radius: 10px;
            }

            .empty-state {
                background: white;
                padding: 42px;
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                text-align: center;
                color: var(--muted);
            }

            .thumb {
                width: 52px;
                height: 52px;
                object-fit: cover;
                border-radius: 8px;
                border: 1px solid var(--border);
                cursor: zoom-in;
                display: block;
            }

            .no-img {
                font-size: 22px;
            }

            .modal {
                position: fixed;
                inset: 0;
                background: rgba(15,23,42,.55);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 1000;
                padding: 16px;
            }

            .modal-card {
                background: #fff;
                border-radius: var(--radius);
                padding: 26px;
                width: 100%;
                max-width: 560px;
                box-shadow: 0 20px 50px rgba(0,0,0,.3);
                max-height: 90vh;
                overflow-y: auto;
            }

                .modal-card h2 {
                    margin-top: 0;
                }

            .lightbox {
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.88);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 2000;
                padding: 20px;
                cursor: zoom-out;
            }

                .lightbox img {
                    max-width: 92vw;
                    max-height: 92vh;
                    border-radius: 12px;
                    box-shadow: 0 20px 60px rgba(0,0,0,.6);
                }

            @@media (max-width: 900px) {
                .dashboard {
                    grid-template-columns: 1fr;
                }

                .sidebar {
                    display: none;
                }

                .content {
                    padding: 24px 16px;
                }

                .form-grid {
                    grid-template-columns: 1fr;
                }
            }
    </style>
</head>

<body>
    <div class="dashboard">
        <aside class="sidebar">
            <div class="logo">
                <div class="logo-icon">🌱</div>
                <div class="logo-text">Smart <span>Biodiversity</span></div>
            </div>
            <p class="menu-title">MENÚ</p>
            <nav class="menu">
                <a asp-controller="Administracion" asp-action="Index" class="menu-item">▦ Dashboard</a>
                <a asp-controller="Administracion" asp-action="InventarioEspecies" class="menu-item active">🌿 Inventario Especies</a>
                <a href="#" class="menu-item">🔬 Taxonomía</a>
                <a href="#" class="menu-item">🗺️ Mapa Campus</a>
                <a href="#" class="menu-item">📊 Reportes</a>
            </nav>
            <div class="profile">
                <div class="avatar">A</div>
                <div class="profile-info"><strong>Perfil</strong><span>Administrador Principal</span></div>
            </div>
        </aside>

        <main class="main">
            <header class="topbar">
                <div class="topbar-brand">🌱 Smart Biodiversity</div>
                <a asp-controller="Administracion" asp-action="InventarioEspecies" class="back-button">← Volver al inventario</a>
            </header>

            <section class="content">
                <div class="page-title">
                    <h1>🦋 Inventario de Fauna</h1>
                    <p>Registra, edita y elimina las especies animales del Campus El Olivo.</p>
                </div>

                @if (TempData["FaunaOk"] is string okMsg)
                {
                    <div class="alert alert-ok">✅ @okMsg</div>
                }
                @if (TempData["FaunaError"] is string errMsg)
                {
                    <div class="alert alert-err">⚠️ @errMsg</div>
                }

                @* ===== Formulario de registro (con imagen) ===== *@
                <div class="panel">
                    <h2>➕ Registrar nueva especie de fauna</h2>
                    @if (string.IsNullOrEmpty(ViewBag.FaunaCategoryId as string))
                    {
                        <p class="warn">⚠️ No se encontró la categoría <strong>“Fauna”</strong> en el sistema. Créala primero para poder registrar especies aquí.</p>
                    }
                    else
                    {
                        <form asp-controller="Administracion" asp-action="FaunaCreate" method="post" enctype="multipart/form-data" class="form-grid">
                            <input type="hidden" name="CategoriaId" value="@ViewBag.FaunaCategoryId" />
                            <label>Nombre común *<input name="NombreComun" required maxlength="150" placeholder="Ej: Colibrí andino" /></label>
                            <label>Nombre científico *<input name="NombreCientifico" required maxlength="150" placeholder="Ej: Amazilia franciae" /></label>
                            <label>Hábitat<input name="Habitat" maxlength="150" placeholder="Ej: Bosque húmedo del campus" /></label>
                            <label>Imagen (opcional)<input type="file" name="archivo" accept="image/*" /></label>
                            <label class="full">Descripción<textarea name="Descripcion" rows="3" maxlength="1000" placeholder="Características, comportamiento, etc."></textarea></label>
                            <div class="full actions">
                                <button type="submit" class="btn btn-primary">🦋 Registrar especie</button>
                            </div>
                        </form>
                    }
                </div>

                @* ===== Tabla (con miniatura clicable) ===== *@
                <div class="panel">
                    <h2>📋 Especies de fauna registradas (@(Model?.Count() ?? 0))</h2>
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-wrap">
                            <table class="tbl">
                                <thead>
                                    <tr><th>#</th><th>Foto</th><th>Nombre común</th><th>Nombre científico</th><th>Hábitat</th><th>Estado</th><th>Fecha registro</th><th class="right">Acciones</th></tr>
                                </thead>
                                <tbody>
                                    @{
                                        int idx = 1;
                                    }
                                    @foreach (var e in Model)
                                    {
                                        var estLabel = e.EstadoEsp == EstadoEspecie.Activo ? "Activo" : e.EstadoEsp == EstadoEspecie.Inactivo ? "Inactivo" : "En revisión";
                                        var estClass = e.EstadoEsp == EstadoEspecie.Activo ? "b-ok" : e.EstadoEsp == EstadoEspecie.Inactivo ? "b-off" : "b-rev";
                                        <tr>
                                            <td>@(idx++)</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(e.ImagenUrl))
                                                {
                                                    <img src="@e.ImagenUrl" class="thumb" alt="@e.NombreComun" onclick="openLightbox(this.src)" />
                                                }
                                                else
                                                {
                                                    <span class="no-img" title="Sin imagen">📷</span>
                                                }
                                            </td>
                                            <td><strong>@e.NombreComun</strong></td>
                                            <td><em>@e.NombreCientifico</em></td>
                                            <td>@(string.IsNullOrWhiteSpace(e.Habitat) ? "—" : e.Habitat)</td>
                                            <td><span class="badge @estClass">@estLabel</span></td>
                                            <td>@e.FechaRegistroEsp.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="right">
                                                <button type="button" class="btn btn-edit" onclick="openEdit(this)"
                                                        data-id="@e.IdEspecie" data-nombre="@e.NombreComun" data-cientifico="@e.NombreCientifico"
                                                        data-desc="@e.Descripcion" data-habitat="@e.Habitat" data-estado="@((int)e.EstadoEsp)">
                                                    ✏️ Editar
                                                </button>
                                                <form asp-controller="Administracion" asp-action="FaunaDelete" method="post" style="display:inline"
                                                      onsubmit="return confirm('¿Eliminar esta especie? Esta acción no se puede deshacer.');">
                                                    <input type="hidden" name="id" value="@e.IdEspecie" />
                                                    <button type="submit" class="btn btn-del">🗑️ Eliminar</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state"><h2>🦋 No hay especies de fauna registradas</h2><p>Usa el formulario de arriba para registrar la primera.</p></div>
                    }
                </div>
            </section>
        </main>
    </div>

    @* ===== Modal editar ===== *@
    <div id="editModal" class="modal" style="display:none" onclick="if(event.target===this)closeEdit()">
        <div class="modal-card">
            <h2>✏️ Editar especie</h2>
            <form asp-controller="Administracion" asp-action="FaunaEdit" method="post" enctype="multipart/form-data" class="form-grid">
                <input type="hidden" id="editId" name="id" />
                <label>Nombre común *<input id="editNombre" name="NombreComun" required maxlength="150" /></label>
                <label>Nombre científico *<input id="editCientifico" name="NombreCientifico" required maxlength="150" /></label>
                <label>Hábitat<input id="editHabitat" name="Habitat" maxlength="150" /></label>
                <label>
                    Estado
                    <select id="editEstado" name="EstadoEsp">
                        <option value="1">Activo</option>
                        <option value="2">Inactivo</option>
                        <option value="3">En revisión</option>
                    </select>
                </label>
                <label>Agregar nueva imagen (opcional)<input type="file" name="archivo" accept="image/*" /></label>
                <label class="full">Descripción<textarea id="editDescripcion" name="Descripcion" rows="3" maxlength="1000"></textarea></label>
                <div class="full actions">
                    <button type="button" class="btn btn-ghost" onclick="closeEdit()">Cancelar</button>
                    <button type="submit" class="btn btn-primary">💾 Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>

    @* ===== Lightbox (ver imagen en grande) ===== *@
    <div id="lightbox" class="lightbox" style="display:none" onclick="closeLightbox()">
        <img id="lightboxImg" src="" alt="Vista ampliada" />
    </div>

    <script>
            function openEdit(btn) {
                document.getElementById('editId').value          = btn.dataset.id || '';
                document.getElementById('editNombre').value      = btn.dataset.nombre || '';
                document.getElementById('editCientifico').value  = btn.dataset.cientifico || '';
                document.getElementById('editDescripcion').value = btn.dataset.desc || '';
                document.getElementById('editHabitat').value     = btn.dataset.habitat || '';
                document.getElementById('editEstado').value      = btn.dataset.estado || '1';
                document.getElementById('editModal').style.display = 'flex';
            }
            function closeEdit() { document.getElementById('editModal').style.display = 'none'; }

            function openLightbox(src) {
                document.getElementById('lightboxImg').src = src;
                document.getElementById('lightbox').style.display = 'flex';
            }
            function closeLightbox() {
                document.getElementById('lightbox').style.display = 'none';
                document.getElementById('lightboxImg').src = '';
            }

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { closeEdit(); closeLightbox(); }
            });
    </script>
</body>
</html>
