@using SmartBiodiversityUtnModels.DTOs.Account
@model IEnumerable<SmartBiodiversityUtnModels.DTOs.Account.UserListResponse>

@{
    Layout = null;
    ViewData["Title"] = "Usuarios";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Usuarios - Smart Biodiversity</title>
    <style>
            :root {
                --bg: #f4f6fa;
                --sidebar: #162232;
                --sidebar-light: #223044;
                --primary: #22c55e;
                --blue: #2563eb;
                --text: #111827;
                --muted: #6b7280;
                --card: #fff;
                --border: #e5e7eb;
                --radius: 16px;
                --shadow: 0 10px 25px rgba(15,23,42,.08);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: Arial,Helvetica,sans-serif;
                background: var(--bg);
                color: var(--text);
            }

            .dashboard {
                display: grid;
                grid-template-columns: 260px 1fr;
                min-height: 100vh;
            }

            .sidebar {
                background: var(--sidebar);
                color: #fff;
                padding: 24px 16px;
                display: flex;
                flex-direction: column;
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 40px;
            }

            .logo-icon {
                width: 42px;
                height: 42px;
                border-radius: 10px;
                background: var(--primary);
                display: grid;
                place-items: center;
                font-size: 22px;
            }

            .logo-text {
                font-weight: bold;
                line-height: 1.1;
            }

                .logo-text span {
                    color: var(--primary);
                    display: block;
                }

            .menu-title {
                font-size: 12px;
                color: #94a3b8;
                margin: 0 0 12px 8px;
                letter-spacing: 1px;
            }

            .menu {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            .menu-item {
                display: block;
                padding: 14px 16px;
                border-radius: 10px;
                color: #cbd5e1;
                text-decoration: none;
                font-size: 15px;
            }

                .menu-item:hover {
                    background: var(--sidebar-light);
                }

                .menu-item.active {
                    background: rgba(34,197,94,.15);
                    color: var(--primary);
                    font-weight: bold;
                    border-right: 4px solid var(--primary);
                }

            .profile {
                margin-top: auto;
                background: var(--sidebar-light);
                border-radius: 14px;
                padding: 16px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .avatar {
                width: 42px;
                height: 42px;
                border-radius: 50%;
                background: #6366f1;
                display: grid;
                place-items: center;
                font-weight: bold;
            }

            .profile-info strong {
                display: block;
                font-size: 15px;
            }

            .profile-info span {
                color: #94a3b8;
                font-size: 13px;
            }

            .main {
                display: flex;
                flex-direction: column;
            }

            .topbar {
                height: 72px;
                padding: 0 28px;
                background: #fff;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .topbar-brand {
                font-size: 20px;
                font-weight: bold;
            }

            .back-button {
                background: #dbeafe;
                color: #1d4ed8;
                text-decoration: none;
                border-radius: 10px;
                padding: 10px 16px;
                font-weight: bold;
            }

            .content {
                padding: 32px;
            }

            .page-title h1 {
                margin: 0;
                font-size: 30px;
            }

            .page-title p {
                color: var(--muted);
                margin: 8px 0 28px;
            }

            .panel {
                background: var(--card);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                padding: 24px;
                margin-bottom: 26px;
            }

                .panel h2 {
                    margin: 0 0 18px;
                    font-size: 20px;
                }

            .toolbar {
                display: flex;
                gap: 12px;
                align-items: center;
                flex-wrap: wrap;
                margin-bottom: 16px;
            }

            .search {
                flex: 1;
                min-width: 220px;
                padding: 10px 12px;
                border: 1px solid var(--border);
                border-radius: 10px;
                font: inherit;
            }

            .count {
                color: var(--muted);
                font-size: 13px;
            }

            .table-wrap {
                overflow-x: auto;
            }

            .tbl {
                width: 100%;
                border-collapse: collapse;
                font-size: 14px;
            }

                .tbl th, .tbl td {
                    text-align: left;
                    padding: 12px 14px;
                    border-bottom: 1px solid var(--border);
                    vertical-align: middle;
                }

                .tbl thead th {
                    background: #f9fafb;
                    color: #374151;
                    font-size: 12px;
                    text-transform: uppercase;
                    letter-spacing: .5px;
                }

                .tbl tbody tr:hover {
                    background: #f9fafb;
                }

            .badge {
                display: inline-block;
                padding: 4px 10px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: bold;
            }

            .b-ok {
                background: #dcfce7;
                color: #166534;
            }

            .b-off {
                background: #fee2e2;
                color: #991b1b;
            }

            .b-rol {
                background: #dbeafe;
                color: #1d4ed8;
            }

            .empty-state {
                background: #fff;
                padding: 42px;
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                text-align: center;
                color: var(--muted);
            }

            @@media (max-width:900px) {
                .dashboard {
                    grid-template-columns: 1fr;
                }

                .sidebar {
                    display: none;
                }

                .content {
                    padding: 24px 16px;
                }
            }
    </style>
</head>
<body>
    <div class="dashboard">
        <aside class="sidebar">
            <div class="logo"><div class="logo-icon">🌱</div><div class="logo-text">Smart <span>Biodiversity</span></div></div>
            <p class="menu-title">MENÚ</p>
            <nav class="menu">
                <a asp-controller="Administracion" asp-action="Index" class="menu-item">▦ Dashboard</a>
                <a asp-controller="Administracion" asp-action="InventarioEspecies" class="menu-item">🌿 Inventario Especies</a>
                <a asp-controller="Administracion" asp-action="Usuarios" class="menu-item active">👥 Usuarios</a>
                <a asp-controller="Administracion" asp-action="Reportes" class="menu-item">📊 Reportes</a>
                <a href="#" class="menu-item">🔬 Taxonomía</a>
                <a href="#" class="menu-item">🗺️ Mapa Campus</a>
            </nav>
            <div class="profile"><div class="avatar">A</div><div class="profile-info"><strong>Perfil</strong><span>Administrador Principal</span></div></div>
        </aside>

        <main class="main">
            <header class="topbar">
                <div class="topbar-brand">🌱 Smart Biodiversity</div>
                <a asp-controller="Administracion" asp-action="Index" class="back-button">← Volver al dashboard</a>
            </header>

            <section class="content">
                <div class="page-title">
                    <h1>👥 Usuarios registrados</h1>
                    <p>Listado de usuarios del sistema y sus aportes.</p>
                </div>

                <div class="panel">
                    <div class="toolbar">
                        <input id="buscar" class="search" type="search" placeholder="🔎 Buscar por nombre, correo o rol..." oninput="filtrar()" />
                        <span class="count" id="contador"></span>
                    </div>

                    @if (Model != null && Model.Any())
                    {
                        <div class="table-wrap">
                            <table class="tbl">
                                <thead>
                                    <tr><th>#</th><th>Nombre completo</th><th>Correo</th><th>Rol</th><th>Estado</th><th>Aportes</th><th>Fecha registro</th></tr>
                                </thead>
                                <tbody>
                                    @{
                                        int idx = 1;
                                    }
                                    @foreach (var u in Model)
                                    {
                                        var estOk = string.Equals(u.Estado, "Activo", StringComparison.OrdinalIgnoreCase);
                                        <tr class="urow" data-text="@($"{u.Nombres} {u.Apellidos} {u.Correo} {u.NombreRol}".ToLower())">
                                            <td>@(idx++)</td>
                                            <td><strong>@u.Nombres @u.Apellidos</strong></td>
                                            <td>@u.Correo</td>
                                            <td><span class="badge b-rol">@u.NombreRol</span></td>
                                            <td><span class="badge @(estOk ? "b-ok" : "b-off")">@u.Estado</span></td>
                                            <td>@u.TotalAportes</td>
                                            <td>@u.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state"><h2>👥 No hay usuarios registrados</h2></div>
                    }
                </div>
            </section>
        </main>
    </div>

    <script>
            function filtrar() {
                var q = (document.getElementById('buscar').value || '').trim().toLowerCase();
                var rows = document.querySelectorAll('.urow');
                var visibles = 0;
                rows.forEach(function (r) {
                    var match = !q || r.dataset.text.indexOf(q) !== -1;
                    r.style.display = match ? '' : 'none';
                    if (match) visibles++;
                });
                document.getElementById('contador').textContent = visibles + ' de ' + rows.length + ' usuarios';
            }
            filtrar();
    </script>
</body>
</html>
