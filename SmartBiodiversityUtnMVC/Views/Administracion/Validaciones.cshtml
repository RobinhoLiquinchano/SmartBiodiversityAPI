@using SmartBiodiversityUtnModels.DTOs
@using SmartBiodiversityUtnModels.DTOs.Aporte
@model IEnumerable<SmartBiodiversityUtnModels.DTOs.Aporte.AporteResponse>

@{
    Layout = null;
    ViewData["Title"] = "Validación de Aportes";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Validación de Aportes - Smart Biodiversity</title>
    <style>
            :root {
                --bg: #f4f6fa;
                --sidebar: #162232;
                --primary: #22c55e;
                --primary-dark: #16a34a;
                --blue: #2563eb;
                --text: #111827;
                --muted: #6b7280;
                --card: #ffffff;
                --border: #e5e7eb;
                --radius: 16px;
                --shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                background: var(--bg);
                color: var(--text);
            }

            .dashboard {
                display: block;
            }

            .main {
                margin-left: 260px;
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            .topbar {
                height: 72px;
                background: white;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 28px;
            }

            .topbar-brand {
                display: flex;
                align-items: center;
                gap: 10px;
                font-weight: bold;
                font-size: 20px;
            }

            .content {
                padding: 32px;
            }

            .page-title h1 {
                margin: 0;
                font-size: 30px;
            }

            .page-title p {
                color: var(--muted);
                margin: 8px 0 0;
            }

            .stats-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 20px;
                margin-bottom: 28px;
            }

            .stat-card {
                background: var(--card);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                padding: 24px;
                display: flex;
                gap: 18px;
                align-items: center;
            }

            .stat-icon {
                width: 56px;
                height: 56px;
                border-radius: 14px;
                display: grid;
                place-items: center;
                font-size: 26px;
            }

            .stat-title {
                color: var(--muted);
                font-size: 15px;
                margin-bottom: 8px;
            }

            .stat-value {
                font-size: 32px;
                font-weight: bold;
            }

            .card {
                background: var(--card);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                overflow: hidden;
            }

            .card-header {
                padding: 24px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                border-bottom: 1px solid var(--border);
            }

                .card-header h2 {
                    margin: 0;
                    font-size: 22px;
                }

            .filter-group {
                display: flex;
                gap: 8px;
            }

            .filter-btn {
                padding: 8px 16px;
                border: 1px solid var(--border);
                background: white;
                border-radius: 8px;
                cursor: pointer;
                font-weight: 500;
                font-size: 14px;
                transition: all 0.2s;
            }

                .filter-btn:hover {
                    background: #f9fafb;
                }

                .filter-btn.active {
                    background: var(--blue);
                    color: white;
                    border-color: var(--blue);
                }

            .table-wrap {
                overflow-x: auto;
            }

            table {
                width: 100%;
                border-collapse: collapse;
                min-width: 900px;
            }

            th, td {
                text-align: left;
                padding: 16px 24px;
                border-bottom: 1px solid var(--border);
                font-size: 14px;
            }

            th {
                color: var(--muted);
                background: #f9fafb;
                font-weight: bold;
                font-size: 12px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .thumbnail {
                width: 50px;
                height: 50px;
                object-fit: cover;
                border-radius: 8px;
                cursor: pointer;
                transition: transform 0.2s;
            }

                .thumbnail:hover {
                    transform: scale(1.1);
                }

            .no-file {
                width: 50px;
                height: 50px;
                background: #f3f4f6;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 24px;
                color: var(--muted);
            }

            .badge {
                display: inline-block;
                padding: 4px 12px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: bold;
            }

            .badge-pending {
                background: #fef3c7;
                color: #92400e;
            }

            .badge-approved {
                background: #d1fae5;
                color: #065f46;
            }

            .badge-rejected {
                background: #fee2e2;
                color: #991b1b;
            }

            .btn-group {
                display: flex;
                gap: 8px;
            }

            .btn {
                padding: 6px 12px;
                border: none;
                border-radius: 6px;
                cursor: pointer;
                font-weight: 500;
                font-size: 13px;
                transition: all 0.2s;
            }

            .btn-approve {
                background: #d1fae5;
                color: #065f46;
            }

                .btn-approve:hover {
                    background: #a7f3d0;
                }

            .btn-reject {
                background: #fee2e2;
                color: #991b1b;
            }

                .btn-reject:hover {
                    background: #fecaca;
                }

            .btn-view {
                background: #dbeafe;
                color: #1e40af;
            }

                .btn-view:hover {
                    background: #bfdbfe;
                }

            .btn-delete {
                background: #f3f4f6;
                color: #6b7280;
            }

                .btn-delete:hover {
                    background: #e5e7eb;
                }

            .alert {
                padding: 16px 20px;
                border-radius: 12px;
                margin-bottom: 20px;
                font-weight: 500;
            }

            .alert-success {
                background: #d1fae5;
                color: #065f46;
            }

            .alert-error {
                background: #fee2e2;
                color: #991b1b;
            }

            .modal {
                display: none;
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0,0,0,0.5);
                z-index: 1000;
                align-items: center;
                justify-content: center;
            }

                .modal.open {
                    display: flex;
                }

            .modal-content {
                background: white;
                border-radius: var(--radius);
                max-width: 800px;
                width: 90%;
                max-height: 90vh;
                overflow-y: auto;
            }

            .modal-header {
                padding: 24px;
                border-bottom: 1px solid var(--border);
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .modal-body {
                padding: 24px;
            }

            .modal-close {
                background: none;
                border: none;
                font-size: 24px;
                cursor: pointer;
                color: var(--muted);
            }

            .detail-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 20px;
            }

            .detail-item {
                margin-bottom: 16px;
            }

            .detail-label {
                font-size: 12px;
                color: var(--muted);
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 4px;
            }

            .detail-value {
                font-size: 15px;
            }

            .detail-image {
                width: 100%;
                border-radius: 12px;
                margin-top: 16px;
            }

            @@media (max-width: 900px) {
                .main {
                    margin-left: 0;
                }

                .stats-grid {
                    grid-template-columns: repeat(2, 1fr);
                }

                .detail-grid {
                    grid-template-columns: 1fr;
                }
            }
    </style>
</head>
<body>

    <div class="dashboard">
        @await Html.PartialAsync("_AdminSidebar")

        <div class="main">
            <div class="topbar">
                <div class="topbar-brand">✅ Validación de Aportes</div>
            </div>

            <div class="content">
                <div class="page-title">
                    <h1>Gestión de Aportes</h1>
                    <p>Revisa y valida los aportes enviados por los usuarios</p>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-error">@TempData["Error"]</div>
                }

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: #dbeafe;">📊</div>
                        <div>
                            <div class="stat-title">Total Aportes</div>
                            <div class="stat-value">@(Model?.Count() ?? 0)</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: #fef3c7;">⏳</div>
                        <div>
                            <div class="stat-title">Pendientes</div>
                            <div class="stat-value">@(Model?.Count(a => a.EstadoApo == EstadoAporte.Pendiente) ?? 0)</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: #d1fae5;">✅</div>
                        <div>
                            <div class="stat-title">Aprobados</div>
                            <div class="stat-value">@(Model?.Count(a => a.EstadoApo == EstadoAporte.Aprobado) ?? 0)</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: #fee2e2;">❌</div>
                        <div>
                            <div class="stat-title">Rechazados</div>
                            <div class="stat-value">@(Model?.Count(a => a.EstadoApo == EstadoAporte.Rechazado) ?? 0)</div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h2>Lista de Aportes</h2>
                        <div class="filter-group">
                            <button class="filter-btn active" data-filter="todos">Todos</button>
                            <button class="filter-btn" data-filter="pendiente">Pendientes</button>
                            <button class="filter-btn" data-filter="aprobado">Aprobados</button>
                            <button class="filter-btn" data-filter="rechazado">Rechazados</button>
                        </div>
                    </div>
                    <div class="table-wrap">
                        <table id="aportes-table">
                            <thead>
                                <tr>
                                    <th>Archivo</th>
                                    <th>Título</th>
                                    <th>Descripción</th>
                                    <th>Usuario</th>
                                    <th>Fecha</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var aporte in Model)
                                    {
                                        var estadoClass = aporte.EstadoApo == EstadoAporte.Pendiente ? "badge-pending" :
                                                         aporte.EstadoApo == EstadoAporte.Aprobado ? "badge-approved" : "badge-rejected";
                                        var estadoText = aporte.EstadoApo == EstadoAporte.Pendiente ? "Pendiente" :
                                                        aporte.EstadoApo == EstadoAporte.Aprobado ? "Aprobado" : "Rechazado";

                                        <tr data-estado="@aporte.EstadoApo.ToString().ToLower()">
                                            <td>
                                                @if (!string.IsNullOrEmpty(aporte.RutaArchivoApo))
                                                {
                                                    <img src="@aporte.RutaArchivoApo" class="thumbnail"
                                                         onclick="verImagen('@aporte.RutaArchivoApo')" alt="Archivo">
                                                }
                                                else
                                                {
                                                    <div class="no-file">📄</div>
                                                }
                                            </td>
                                            <td><strong>@aporte.TituloApo</strong></td>
                                            <td>@(aporte.DescripcionApo ?? "Sin descripción")</td>
                                            <td>
                                                <div>@(aporte.NombreUsuario ?? "Usuario")</div>
                                                <small style="color: var(--muted);">@(aporte.CorreoUsuario ?? "")</small>
                                            </td>
                                            <td>@aporte.FechaCreacionApo.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td><span class="badge @estadoClass">@estadoText</span></td>
                                            <td>
                                                <div class="btn-group">
                                                    <button class="btn btn-view"
                                                            onclick='verDetalle(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(aporte)))'>
                                                        👁️ Ver
                                                    </button>
                                                    @if (aporte.EstadoApo == EstadoAporte.Pendiente)
                                                    {
                                                        <button class="btn btn-approve" onclick="aprobarAporte('@aporte.IdAporte')">
                                                            ✅ Aprobar
                                                        </button>
                                                        <button class="btn btn-reject" onclick="rechazarAporte('@aporte.IdAporte')">
                                                            ❌ Rechazar
                                                        </button>
                                                    }
                                                    <button class="btn btn-delete" onclick="eliminarAporte('@aporte.IdAporte')">
                                                        🗑️
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" style="text-align: center; padding: 40px; color: var(--muted);">
                                            No hay aportes registrados
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de Detalle -->
    <div class="modal" id="detalleModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Detalle del Aporte</h2>
                <button class="modal-close" onclick="cerrarModal()">×</button>
            </div>
            <div class="modal-body" id="detalleContenido">
                <!-- Contenido dinámico -->
            </div>
        </div>
    </div>

    <script>
            const API_BASE = 'https://smartbiodiversityapi.onrender.com';

            // Filtros
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');

                    const filter = this.dataset.filter;
                    const rows = document.querySelectorAll('#aportes-table tbody tr');

                    rows.forEach(row => {
                        if (filter === 'todos' || row.dataset.estado === filter) {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    });
                });
            });

            async function aprobarAporte(id) {
                if (!confirm('¿Estás seguro de aprobar este aporte?')) return;

                try {
                    const response = await fetch(`${API_BASE}/api/Aportes/${id}/aprobar`, {
                        method: 'PUT',
                        headers: {
                            'Authorization': `Bearer ${getCookie('AccessToken')}`
                        }
                    });

                    if (!response.ok) throw new Error('Error al aprobar');

                    location.reload();
                } catch (error) {
                    alert('Error al aprobar: ' + error.message);
                }
            }

            async function rechazarAporte(id) {
                if (!confirm('¿Estás seguro de rechazar este aporte?')) return;

                try {
                    const response = await fetch(`${API_BASE}/api/Aportes/${id}/rechazar`, {
                        method: 'PUT',
                        headers: {
                            'Authorization': `Bearer ${getCookie('AccessToken')}`
                        }
                    });

                    if (!response.ok) throw new Error('Error al rechazar');

                    location.reload();
                } catch (error) {
                    alert('Error al rechazar: ' + error.message);
                }
            }

            async function eliminarAporte(id) {
                if (!confirm('¿Estás seguro de eliminar este aporte? Esta acción no se puede deshacer.')) return;

                try {
                    const response = await fetch(`${API_BASE}/api/Aportes/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Authorization': `Bearer ${getCookie('AccessToken')}`
                        }
                    });

                    if (!response.ok) throw new Error('Error al eliminar');

                    location.reload();
                } catch (error) {
                    alert('Error al eliminar: ' + error.message);
                }
            }

            function verDetalle(aporte) {
                const estadoClass = aporte.estadoApo === 0 ? "badge-pending" :
                                   aporte.estadoApo === 1 ? "badge-approved" : "badge-rejected";
                const estadoText = aporte.estadoApo === 0 ? "Pendiente" :
                                  aporte.estadoApo === 1 ? "Aprobado" : "Rechazado";

                const contenido = `
                    <div class="detail-grid">
                        <div>
                            <div class="detail-item">
                                <div class="detail-label">Título</div>
                                <div class="detail-value">${aporte.tituloApo}</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Descripción</div>
                                <div class="detail-value">${aporte.descripcionApo || 'Sin descripción'}</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Usuario</div>
                                <div class="detail-value">
                                    ${aporte.nombreUsuario || 'Usuario'}<br>
                                    <small style="color: var(--muted);">${aporte.correoUsuario || ''}</small>
                                </div>
                            </div>
                        </div>
                        <div>
                            <div class="detail-item">
                                <div class="detail-label">Estado</div>
                                <div class="detail-value"><span class="badge ${estadoClass}">${estadoText}</span></div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Fecha de Creación</div>
                                <div class="detail-value">${new Date(aporte.fechaCreacionApo).toLocaleString('es-ES')}</div>
                            </div>
                            ${aporte.fechaAprobacionApo ? `
                                <div class="detail-item">
                                    <div class="detail-label">Fecha de Aprobación</div>
                                    <div class="detail-value">${new Date(aporte.fechaAprobacionApo).toLocaleString('es-ES')}</div>
                                </div>
                            ` : ''}
                        </div>
                    </div>
                    ${aporte.rutaArchivoApo ? `
                        <img src="${aporte.rutaArchivoApo}" class="detail-image" alt="Archivo">
                    ` : ''}
                `;

                document.getElementById('detalleContenido').innerHTML = contenido;
                document.getElementById('detalleModal').classList.add('open');
            }

            function verImagen(url) {
                const contenido = `<img src="${url}" style="width: 100%; border-radius: 12px;" alt="Imagen">`;
                document.getElementById('detalleContenido').innerHTML = contenido;
                document.getElementById('detalleModal').classList.add('open');
            }

            function cerrarModal() {
                document.getElementById('detalleModal').classList.remove('open');
            }

            function getCookie(name) {
                const value = `; ${document.cookie}`;
                const parts = value.split(`; ${name}=`);
                if (parts.length === 2) return parts.pop().split(';').shift();
                return null;
            }

            // Cerrar modal con ESC
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') cerrarModal();
            });
    </script>

</body>
</html>
