@model IEnumerable<SmartBiodiversityUtnModels.DTOs.Especie.EspecieResponse>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smart Biodiversity - Dashboard</title>

    <style>
            :root {
                --bg: #f4f6fa;
                --sidebar: #162232;
                --sidebar-light: #223044;
                --primary: #22c55e;
                --primary-dark: #16a34a;
                --blue: #2563eb;
                --text: #111827;
                --muted: #6b7280;
                --card: #ffffff;
                --border: #e5e7eb;
                --danger: #dc2626;
                --success-bg: #ecfdf5;
                --success-text: #16a34a;
                --radius: 16px;
                --shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                background: var(--bg);
                color: var(--text);
            }

            .dashboard {
                display: grid;
                grid-template-columns: 260px 1fr;
                min-height: 100vh;
            }

            .sidebar {
                background: var(--sidebar);
                color: white;
                padding: 24px 16px;
                display: flex;
                flex-direction: column;
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 40px;
            }

            .logo-icon {
                width: 42px;
                height: 42px;
                border-radius: 10px;
                background: var(--primary);
                display: grid;
                place-items: center;
                font-size: 22px;
            }

            .logo-text {
                font-weight: bold;
                line-height: 1.1;
            }

                .logo-text span {
                    color: var(--primary);
                    display: block;
                }

            .menu-title {
                font-size: 12px;
                color: #94a3b8;
                margin: 0 0 12px 8px;
                letter-spacing: 1px;
            }

            .menu {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            .menu-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 14px 16px;
                border-radius: 10px;
                color: #cbd5e1;
                text-decoration: none;
                font-size: 15px;
            }

                .menu-item.active {
                    background: rgba(34, 197, 94, 0.15);
                    color: var(--primary);
                    font-weight: bold;
                    border-right: 4px solid var(--primary);
                }

                .menu-item:hover {
                    background: var(--sidebar-light);
                }

            .profile {
                margin-top: auto;
                background: var(--sidebar-light);
                border-radius: 14px;
                padding: 16px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .avatar {
                width: 42px;
                height: 42px;
                border-radius: 50%;
                background: #6366f1;
                display: grid;
                place-items: center;
                font-weight: bold;
            }

            .profile-info strong {
                display: block;
                font-size: 15px;
            }

            .profile-info span {
                color: #94a3b8;
                font-size: 13px;
            }

            .main {
                display: flex;
                flex-direction: column;
            }

            .topbar {
                height: 72px;
                background: white;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 28px;
            }

            .topbar-brand {
                display: flex;
                align-items: center;
                gap: 10px;
                font-weight: bold;
                font-size: 20px;
            }

            .campus-select {
                background: white;
                border: 1px solid var(--border);
                padding: 10px 18px;
                border-radius: 10px;
                font-weight: bold;
            }

            .topbar-actions {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .icon-btn {
                width: 42px;
                height: 42px;
                border: 1px solid var(--border);
                border-radius: 12px;
                background: white;
                display: grid;
                place-items: center;
                position: relative;
            }

            .badge {
                position: absolute;
                top: -6px;
                right: -6px;
                background: #ef4444;
                color: white;
                width: 18px;
                height: 18px;
                border-radius: 50%;
                font-size: 11px;
                display: grid;
                place-items: center;
            }

            .content {
                padding: 32px;
            }

            .page-title {
                margin-bottom: 28px;
            }

                .page-title h1 {
                    margin: 0;
                    font-size: 30px;
                }

                .page-title p {
                    color: var(--muted);
                    margin: 8px 0 0;
                }

            .kpi-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 20px;
                margin-bottom: 28px;
            }

            .kpi-card {
                background: var(--card);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                padding: 24px;
                display: flex;
                gap: 18px;
                align-items: center;
                min-height: 120px;
            }

            .kpi-icon {
                width: 56px;
                height: 56px;
                border-radius: 14px;
                background: #f0fdf4;
                display: grid;
                place-items: center;
                font-size: 26px;
            }

            .kpi-title {
                color: var(--muted);
                font-size: 15px;
                margin-bottom: 8px;
            }

            .kpi-value {
                font-size: 32px;
                font-weight: bold;
            }

            .main-grid {
                display: grid;
                grid-template-columns: 1fr 320px;
                gap: 24px;
            }

            .card {
                background: var(--card);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                overflow: hidden;
            }

            .card-header {
                padding: 24px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                border-bottom: 1px solid var(--border);
            }

                .card-header h2 {
                    margin: 0;
                    font-size: 22px;
                }

                .card-header p {
                    color: var(--muted);
                    margin: 6px 0 0;
                    font-size: 14px;
                }

            table {
                width: 100%;
                border-collapse: collapse;
                min-width: 760px;
            }

            th, td {
                text-align: left;
                padding: 16px 24px;
                border-bottom: 1px solid var(--border);
                font-size: 14px;
                white-space: nowrap;
            }

            th {
                color: var(--muted);
                background: #f9fafb;
                font-weight: bold;
            }

            .status {
                background: var(--success-bg);
                color: var(--success-text);
                padding: 6px 12px;
                border-radius: 999px;
                font-weight: bold;
                font-size: 13px;
            }

            .quick-actions {
                padding: 24px;
            }

            .action-list {
                display: flex;
                flex-direction: column;
                gap: 14px;
            }

            .action-btn {
                border: 1px solid var(--border);
                background: white;
                border-radius: 12px;
                padding: 16px;
                display: flex;
                align-items: center;
                gap: 14px;
                font-weight: bold;
                cursor: pointer;
                text-align: left;
            }

                .action-btn.primary {
                    background: var(--blue);
                    color: white;
                    border: none;
                }

            .action-icon {
                width: 30px;
                height: 30px;
                display: grid;
                place-items: center;
            }

            dialog::backdrop {
                background: rgba(0, 0, 0, 0.5);
            }

            .modal-input {
                width: 100%;
                padding: 10px;
                border-radius: 8px;
                border: 1px solid var(--border);
                margin-top: 5px;
            }

            @@media (max-width: 1100px) {
                .dashboard {
                    grid-template-columns: 1fr;
                }

                .sidebar {
                    display: none;
                }

                .kpi-grid {
                    grid-template-columns: repeat(2, 1fr);
                }

                .main-grid {
                    grid-template-columns: 1fr;
                }
            }
    </style>
</head>

<body>
    <div class="dashboard">
        @await Html.PartialAsync("_AdminSidebar")

        <main class="main">
            <header class="topbar">
                <div class="topbar-brand">🌱 Smart Biodiversity</div>
                <div class="campus-select">Campus: El Olivo</div>
                <div class="topbar-actions">
                </div>
            </header>

            <section class="content">
                <div class="page-title">
                    <h1>Dashboard: Principal</h1>
                    <p>Campus: El Olivo</p>
                </div>

                @if (TempData["IndexOk"] is string _ok)
                {
                    <div class="sb-alert sb-ok">✅ @_ok</div>
                }
                @if (TempData["IndexError"] is string _err)
                {
                    <div class="sb-alert sb-err">⚠️ @_err</div>
                }

                @{
                    var _lista = Model ?? Enumerable.Empty<SmartBiodiversityUtnModels.DTOs.Especie.EspecieResponse>();
                    var _total = _lista.Count();
                    var _flora = _lista.Count(e => string.Equals(e.NombreCategoria?.Trim(), "Flora", StringComparison.OrdinalIgnoreCase));
                    var _fauna = _lista.Count(e => string.Equals(e.NombreCategoria?.Trim(), "Fauna", StringComparison.OrdinalIgnoreCase));
                    var _limite = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-7), DateTimeKind.Unspecified);
                    var _nuevos = _lista.Count(e => e.FechaRegistroEsp >= _limite);
                    var _recientes = _lista.OrderByDescending(e => e.FechaRegistroEsp).ToList();
                }

                <section class="kpi-grid">
                    <article class="kpi-card"><div class="kpi-icon">🌳</div><div><div class="kpi-title">Total Especies</div><div class="kpi-value">@_total</div></div></article>
                    <article class="kpi-card"><div class="kpi-icon">🌸</div><div><div class="kpi-title">Flora</div><div class="kpi-value">@_flora</div></div></article>
                    <article class="kpi-card"><div class="kpi-icon">🦋</div><div><div class="kpi-title">Fauna</div><div class="kpi-value">@_fauna</div></div></article>
                    <article class="kpi-card"><div class="kpi-icon">✨</div><div><div class="kpi-title">Nuevos (7 días)</div><div class="kpi-value">+@_nuevos</div></div></article>
                </section>

                <section class="main-grid">
                    <article class="card">
                        <div class="card-header">
                            <div><h2>Inventario</h2><p>Todas las especies registradas (más recientes primero)</p></div>
                            <div class="inventory-tools"></div>
                        </div>
                        <div class="table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th style="width:44px">Foto</th>
                                        <th>Nombre común</th>
                                        <th>Categoría</th>
                                        <th>Estado</th>
                                        <th>Registrado</th>
                                        <th style="text-align:right">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (_recientes.Any())
                                    {
                                        foreach (var e in _recientes)
                                        {
                                            var estLabel = e.EstadoEsp == SmartBiodiversityUtnModels.DTOs.EstadoEspecie.Activo ? "Activo"
                                                         : e.EstadoEsp == SmartBiodiversityUtnModels.DTOs.EstadoEspecie.Inactivo ? "Inactivo" : "En revisión";
                                            var estPill = e.EstadoEsp == SmartBiodiversityUtnModels.DTOs.EstadoEspecie.Activo ? "sb-pill-ok"
                                                        : e.EstadoEsp == SmartBiodiversityUtnModels.DTOs.EstadoEspecie.Inactivo ? "sb-pill-off" : "sb-pill-rev";
                                            <tr>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(e.ImagenUrl))
                                                    {
                                                        <img src="@e.ImagenUrl" class="sb-thumb" alt="@e.NombreComun" onclick="openLightbox(this.src)" style="cursor:zoom-in" />
                                                    }
                                                    else
                                                    {
                                                        <span class="sb-noimg" title="Sin imagen">📷</span>
                                                    }
                                                </td>
                                                <td><strong title="@e.NombreComun">@e.NombreComun</strong></td>
                                                <td><span class="sb-pill sb-pill-cat">@e.NombreCategoria</span></td>
                                                <td><span class="sb-pill @estPill">@estLabel</span></td>
                                                <td>@e.FechaRegistroEsp.ToString("dd/MM/yyyy")</td>
                                                <td style="text-align:right; white-space:nowrap">
                                                    <button type="button" class="sb-btn sb-edit" onclick="openEdit(this)"
                                                            data-id="@e.IdEspecie" data-nombre="@e.NombreComun" data-cientifico="@e.NombreCientifico"
                                                            data-desc="@e.Descripcion" data-habitat="@e.Habitat" data-estado="@((int)e.EstadoEsp)" title="Editar">
                                                        ✏️
                                                    </button>
                                                    <form asp-controller="Administracion" asp-action="EspecieDelete" method="post" style="display:inline"
                                                          onsubmit="return confirm('¿Eliminar esta especie? Esta acción no se puede deshacer.');">
                                                        <input type="hidden" name="id" value="@e.IdEspecie" />
                                                        <button type="submit" class="sb-btn sb-del" title="Eliminar">🗑️</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="6" style="text-align:center; color:var(--muted); padding:24px">Aún no hay especies registradas. Usa “Nuevo Registro”.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </article>

                    <aside class="card quick-actions">
                        <h2>Acciones rápidas</h2>
                        <div class="action-list">
                            <button type="button" class="action-btn primary" onclick="openCreate()">
                                <span class="action-icon">+</span> Nuevo Registro
                            </button>
                            <a asp-controller="Administracion" asp-action="Reportes" class="action-btn">
                                <span class="action-icon">📊</span> Generar Reporte
                            </a>
                            <a href="#" class="action-btn"><span class="action-icon">🗺️</span> Ver Mapa Campus</a>
                        </div>
                    </aside>
                </section>
            </section>
        </main>
    </div>

    <style>
            .sb-alert {
                padding: 14px 18px;
                border-radius: 12px;
                margin-bottom: 18px;
                font-weight: bold;
            }

            .sb-ok {
                background: #dcfce7;
                color: #166534;
                border: 1px solid #86efac;
            }

            .sb-err {
                background: #fee2e2;
                color: #991b1b;
                border: 1px solid #fca5a5;
            }

            .sb-thumb {
                width: 46px;
                height: 46px;
                object-fit: cover;
                border-radius: 8px;
                border: 1px solid var(--border);
                display: block;
            }

            .sb-noimg {
                font-size: 20px;
            }

            .sb-pill {
                display: inline-block;
                padding: 4px 10px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: bold;
            }

            .sb-pill-ok {
                background: #dcfce7;
                color: #166534;
            }

            .sb-pill-off {
                background: #e5e7eb;
                color: #374151;
            }

            .sb-pill-rev {
                background: #fef9c3;
                color: #854d0e;
            }

            .sb-pill-cat {
                background: #dbeafe;
                color: #1d4ed8;
            }

            .sb-btn {
                border: none;
                cursor: pointer;
                font: inherit;
                font-weight: bold;
                border-radius: 8px;
                padding: 8px 12px;
            }

            .sb-edit {
                background: #dbeafe;
                color: #1d4ed8;
            }

            .sb-del {
                background: #fee2e2;
                color: #b91c1c;
            }

            .sb-primary {
                background: var(--primary);
                color: #fff;
                padding: 10px 16px;
            }

            .sb-ghost {
                background: #e5e7eb;
                color: #111827;
                padding: 10px 16px;
            }

            .sb-modal {
                position: fixed;
                inset: 0;
                background: rgba(15,23,42,.55);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 1000;
                padding: 16px;
            }

            .sb-modal-card {
                background: #fff;
                border-radius: 16px;
                padding: 26px;
                width: 100%;
                max-width: 520px;
                box-shadow: 0 20px 50px rgba(0,0,0,.3);
                max-height: 90vh;
                overflow-y: auto;
            }

            .sb-form {
                display: flex;
                flex-direction: column;
                gap: 12px;
            }

                .sb-form label {
                    display: flex;
                    flex-direction: column;
                    font-size: 13px;
                    font-weight: bold;
                    color: #374151;
                    gap: 6px;
                }

                .sb-form input, .sb-form textarea, .sb-form select {
                    font: inherit;
                    padding: 10px 12px;
                    border: 1px solid var(--border);
                    border-radius: 10px;
                    background: #f9fafb;
                    font-weight: normal;
                }

                    .sb-form input[type="file"] {
                        background: #fff;
                        padding: 8px;
                    }

            .sb-actions {
                display: flex;
                gap: 10px;
                justify-content: flex-end;
                margin-top: 6px;
            }

            .sb-lightbox {
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.88);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 2000;
                padding: 20px;
                cursor: zoom-out;
            }

                .sb-lightbox img {
                    max-width: 92vw;
                    max-height: 92vh;
                    border-radius: 12px;
                    box-shadow: 0 20px 60px rgba(0,0,0,.6);
                }

            a.action-btn {
                text-decoration: none;
                color: inherit;
            }

            /* === Tabla del inventario: texto adaptable + scroll horizontal de respaldo === */
            /* ===== Dashboard compacto (ajuste de inspección) ===== */
            .content {
                padding: 20px 22px;
            }

            .page-title {
                margin-bottom: 14px;
            }

                .page-title h1 {
                    font-size: 21px;
                }

                .page-title p {
                    font-size: 13px;
                    margin: 3px 0 0;
                }

            .kpi-grid {
                gap: 12px;
                margin-bottom: 16px;
            }

            .kpi-card {
                padding: 12px 14px;
                min-height: 0;
                gap: 12px;
            }

            .kpi-icon {
                width: 38px;
                height: 38px;
                border-radius: 10px;
                font-size: 17px;
            }

            .kpi-title {
                font-size: 11.5px;
                margin-bottom: 2px;
                letter-spacing: .2px;
            }

            .kpi-value {
                font-size: 21px;
                line-height: 1.1;
            }

            .main-grid {
                gap: 16px;
                grid-template-columns: 1fr 250px;
            }

            .card-header {
                padding: 12px 16px;
            }

                .card-header h2 {
                    font-size: 15px;
                }

                .card-header p {
                    font-size: 12px;
                    margin: 2px 0 0;
                }

            .quick-actions {
                padding: 14px 16px;
            }

            .action-list {
                gap: 9px;
            }

            .action-btn {
                padding: 10px 12px;
                gap: 10px;
                font-size: 13px;
                border-radius: 10px;
            }

            .action-icon {
                width: 20px;
                height: 20px;
                font-size: 14px;
            }

            /* Tabla resumen: horizontal, compacta, una línea por fila (NUNCA vertical) */
            .card .table-wrap {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }

            .card table {
                width: 100%;
                min-width: 0;
                border-collapse: collapse;
            }

                .card table th, .card table td {
                    padding: 7px 10px !important;
                    font-size: 12.5px !important;
                    white-space: nowrap !important;
                    vertical-align: middle;
                }

                .card table th {
                    font-size: 10.5px;
                    text-transform: uppercase;
                    letter-spacing: .4px;
                    color: var(--muted);
                }

                .card table td:nth-child(2) {
                    max-width: 240px;
                }

                    .card table td:nth-child(2) strong {
                        display: block;
                        overflow: hidden;
                        text-overflow: ellipsis;
                    }

            .sb-thumb {
                width: 32px !important;
                height: 32px !important;
                border-radius: 6px;
            }

            .sb-noimg {
                font-size: 16px;
            }

            .sb-pill {
                font-size: 10.5px;
                padding: 2px 8px;
            }

            .sb-btn {
                padding: 4px 8px;
                font-size: 12px;
                border-radius: 7px;
            }
    </style>

    @* ===== Modal: REGISTRAR especie (elige Flora o Fauna + imagen) ===== *@
    <div id="sbCreate" class="sb-modal" style="display:none" onclick="if(event.target===this)closeCreate()">
        <div class="sb-modal-card">
            <h2 style="margin-top:0">➕ Registrar nueva especie</h2>
            <form asp-controller="Administracion" asp-action="EspecieCreate" method="post" enctype="multipart/form-data" class="sb-form">
                <label>
                    Categoría *
                    <select id="sbCreateCat" name="CategoriaId" required onchange="actualizarEjemplos(this)">
                        <option value="">-- Selecciona --</option>
                        @if (ViewBag.FloraId != null)
                        {
                            <option value="@ViewBag.FloraId" data-reino="flora">🌸 Flora</option>
                        }
                        @if (ViewBag.FaunaId != null)
                        {
                            <option value="@ViewBag.FaunaId" data-reino="fauna">🦋 Fauna</option>
                        }
                    </select>
                </label>
                <label>Nombre común *<input id="sbCreateNombre" name="NombreComun" required maxlength="150" placeholder="Selecciona una categoría para ver ejemplos" /></label>
                <label>Nombre científico *<input id="sbCreateCientifico" name="NombreCientifico" required maxlength="150" placeholder="Selecciona una categoría para ver ejemplos" /></label>
                <label>Hábitat<input id="sbCreateHabitat" name="Habitat" maxlength="150" placeholder="Ej: tipo de hábitat" /></label>
                <label>Imagen (opcional)<input type="file" name="archivo" accept="image/*" /></label>
                <label>Descripción<textarea name="Descripcion" rows="6" maxlength="1000" style="min-height:140px; resize:vertical"></textarea></label>
                <div class="sb-actions">
                    <button type="button" class="sb-btn sb-ghost" onclick="closeCreate()">Cancelar</button>
                    <button type="submit" class="sb-btn sb-primary">🌱 Guardar</button>
                </div>
            </form>
        </div>
    </div>

    @* ===== Modal: EDITAR especie ===== *@
    <div id="sbEdit" class="sb-modal" style="display:none" onclick="if(event.target===this)closeEdit()">
        <div class="sb-modal-card">
            <h2 style="margin-top:0">✏️ Editar especie</h2>
            <form asp-controller="Administracion" asp-action="EspecieEdit" method="post" enctype="multipart/form-data" class="sb-form">
                <input type="hidden" id="sbEditId" name="id" />
                <label>Nombre común *<input id="sbEditNombre" name="NombreComun" required maxlength="150" /></label>
                <label>Nombre científico *<input id="sbEditCientifico" name="NombreCientifico" required maxlength="150" /></label>
                <label>Hábitat<input id="sbEditHabitat" name="Habitat" maxlength="150" /></label>
                <label>
                    Estado
                    <select id="sbEditEstado" name="EstadoEsp">
                        <option value="1">Activo</option>
                        <option value="2">Inactivo</option>
                        <option value="3">En revisión</option>
                    </select>
                </label>
                <label>Agregar imagen (opcional)<input type="file" name="archivo" accept="image/*" /></label>
                <label>Descripción<textarea id="sbEditDesc" name="Descripcion" rows="6" maxlength="1000" style="min-height:140px; resize:vertical"></textarea></label>
                <div class="sb-actions">
                    <button type="button" class="sb-btn sb-ghost" onclick="closeEdit()">Cancelar</button>
                    <button type="submit" class="sb-btn sb-primary">💾 Guardar</button>
                </div>
            </form>
        </div>
    </div>

    @* ===== Lightbox ===== *@
    <div id="sbLightbox" class="sb-lightbox" style="display:none" onclick="closeLightbox()">
        <img id="sbLightboxImg" src="" alt="Vista ampliada" />
    </div>

    <script>
            function openCreate() { document.getElementById('sbCreate').style.display = 'flex'; }
            function closeCreate() { document.getElementById('sbCreate').style.display = 'none'; }

            // Cambia los textos de ejemplo según el reino elegido (Flora / Fauna).
            // Robusto: recibe el <select> por 'this' y busca los inputs por NOMBRE dentro de su <form>.
            function actualizarEjemplos(sel) {
                sel = sel || document.getElementById('sbCreateCat');
                if (!sel) return;
                var opt = sel.selectedOptions && sel.selectedOptions[0];
                var txt = (opt ? ((opt.getAttribute('data-reino') || opt.textContent) || '') : '').toLowerCase();

                var form = sel.closest ? sel.closest('form') : null;
                if (!form) return;
                var n = form.querySelector('[name="NombreComun"]');
                var c = form.querySelector('[name="NombreCientifico"]');
                var h = form.querySelector('[name="Habitat"]');

                if (txt.indexOf('fauna') !== -1) {
                    if (n) n.placeholder = 'Ej: Colibrí andino';
                    if (c) c.placeholder = 'Ej: Amazilia franciae';
                    if (h) h.placeholder = 'Ej: Bosque húmedo, sabana, páramo';
                } else if (txt.indexOf('flora') !== -1) {
                    if (n) n.placeholder = 'Ej: Orquídea del campus';
                    if (c) c.placeholder = 'Ej: Cyrtochilum retusum';
                    if (h) h.placeholder = 'Ej: Jardín botánico, bosque nublado';
                } else {
                    if (n) n.placeholder = 'Selecciona Flora o Fauna para ver ejemplos';
                    if (c) c.placeholder = 'Selecciona Flora o Fauna para ver ejemplos';
                    if (h) h.placeholder = 'Ej: tipo de hábitat';
                }
            }
            function openEdit(b) {
                document.getElementById('sbEditId').value = b.dataset.id || '';
                document.getElementById('sbEditNombre').value = b.dataset.nombre || '';
                document.getElementById('sbEditCientifico').value = b.dataset.cientifico || '';
                document.getElementById('sbEditDesc').value = b.dataset.desc || '';
                document.getElementById('sbEditHabitat').value = b.dataset.habitat || '';
                document.getElementById('sbEditEstado').value = b.dataset.estado || '1';
                document.getElementById('sbEdit').style.display = 'flex';
            }
            function closeEdit() { document.getElementById('sbEdit').style.display = 'none'; }
            function openLightbox(s) { document.getElementById('sbLightboxImg').src = s; document.getElementById('sbLightbox').style.display = 'flex'; }
            function closeLightbox() { document.getElementById('sbLightbox').style.display = 'none'; document.getElementById('sbLightboxImg').src = ''; }
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') { closeCreate(); closeEdit(); closeLightbox(); } });
    </script>
</body>
</html>
