@model IEnumerable<SmartBiodiversityUtnModels.DTOs.Especie.EspecieResponse>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smart Biodiversity - Dashboard</title>

    <style>
            :root {
                --bg: #f4f6fa;
                --sidebar: #162232;
                --sidebar-light: #223044;
                --primary: #22c55e;
                --primary-dark: #16a34a;
                --blue: #2563eb;
                --text: #111827;
                --muted: #6b7280;
                --card: #ffffff;
                --border: #e5e7eb;
                --danger: #dc2626;
                --success-bg: #ecfdf5;
                --success-text: #16a34a;
                --radius: 16px;
                --shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                background: var(--bg);
                color: var(--text);
            }

            .dashboard {
                display: grid;
                grid-template-columns: 260px 1fr;
                min-height: 100vh;
            }

            .sidebar {
                background: var(--sidebar);
                color: white;
                padding: 24px 16px;
                display: flex;
                flex-direction: column;
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 40px;
            }

            .logo-icon {
                width: 42px;
                height: 42px;
                border-radius: 10px;
                background: var(--primary);
                display: grid;
                place-items: center;
                font-size: 22px;
            }

            .logo-text {
                font-weight: bold;
                line-height: 1.1;
            }

                .logo-text span {
                    color: var(--primary);
                    display: block;
                }

            .menu-title {
                font-size: 12px;
                color: #94a3b8;
                margin: 0 0 12px 8px;
                letter-spacing: 1px;
            }

            .menu {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            .menu-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 14px 16px;
                border-radius: 10px;
                color: #cbd5e1;
                text-decoration: none;
                font-size: 15px;
            }

                .menu-item.active {
                    background: rgba(34, 197, 94, 0.15);
                    color: var(--primary);
                    font-weight: bold;
                    border-right: 4px solid var(--primary);
                }

                .menu-item:hover {
                    background: var(--sidebar-light);
                }

            .profile {
                margin-top: auto;
                background: var(--sidebar-light);
                border-radius: 14px;
                padding: 16px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .avatar {
                width: 42px;
                height: 42px;
                border-radius: 50%;
                background: #6366f1;
                display: grid;
                place-items: center;
                font-weight: bold;
            }

            .profile-info strong {
                display: block;
                font-size: 15px;
            }

            .profile-info span {
                color: #94a3b8;
                font-size: 13px;
            }

            .main {
                display: flex;
                flex-direction: column;
            }

            .topbar {
                height: 72px;
                background: white;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 28px;
            }

            .topbar-brand {
                display: flex;
                align-items: center;
                gap: 10px;
                font-weight: bold;
                font-size: 20px;
            }

            .campus-select {
                background: white;
                border: 1px solid var(--border);
                padding: 10px 18px;
                border-radius: 10px;
                font-weight: bold;
            }

            .topbar-actions {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .icon-btn {
                width: 42px;
                height: 42px;
                border: 1px solid var(--border);
                border-radius: 12px;
                background: white;
                display: grid;
                place-items: center;
                position: relative;
            }

            .badge {
                position: absolute;
                top: -6px;
                right: -6px;
                background: #ef4444;
                color: white;
                width: 18px;
                height: 18px;
                border-radius: 50%;
                font-size: 11px;
                display: grid;
                place-items: center;
            }

            .content {
                padding: 32px;
            }

            .page-title {
                margin-bottom: 28px;
            }

                .page-title h1 {
                    margin: 0;
                    font-size: 30px;
                }

                .page-title p {
                    color: var(--muted);
                    margin: 8px 0 0;
                }

            .kpi-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 20px;
                margin-bottom: 28px;
            }

            .kpi-card {
                background: var(--card);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                padding: 24px;
                display: flex;
                gap: 18px;
                align-items: center;
                min-height: 120px;
            }

            .kpi-icon {
                width: 56px;
                height: 56px;
                border-radius: 14px;
                background: #f0fdf4;
                display: grid;
                place-items: center;
                font-size: 26px;
            }

            .kpi-title {
                color: var(--muted);
                font-size: 15px;
                margin-bottom: 8px;
            }

            .kpi-value {
                font-size: 32px;
                font-weight: bold;
            }

            .main-grid {
                display: grid;
                grid-template-columns: 1fr 320px;
                gap: 24px;
            }

            .card {
                background: var(--card);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                overflow: hidden;
            }

            .card-header {
                padding: 24px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                border-bottom: 1px solid var(--border);
            }

                .card-header h2 {
                    margin: 0;
                    font-size: 22px;
                }

                .card-header p {
                    color: var(--muted);
                    margin: 6px 0 0;
                    font-size: 14px;
                }

            table {
                width: 100%;
                border-collapse: collapse;
                min-width: 760px;
            }

            th, td {
                text-align: left;
                padding: 16px 24px;
                border-bottom: 1px solid var(--border);
                font-size: 14px;
                white-space: nowrap;
            }

            th {
                color: var(--muted);
                background: #f9fafb;
                font-weight: bold;
            }

            .status {
                background: var(--success-bg);
                color: var(--success-text);
                padding: 6px 12px;
                border-radius: 999px;
                font-weight: bold;
                font-size: 13px;
            }

            .quick-actions {
                padding: 24px;
            }

            .action-list {
                display: flex;
                flex-direction: column;
                gap: 14px;
            }

            .action-btn {
                border: 1px solid var(--border);
                background: white;
                border-radius: 12px;
                padding: 16px;
                display: flex;
                align-items: center;
                gap: 14px;
                font-weight: bold;
                cursor: pointer;
                text-align: left;
            }

                .action-btn.primary {
                    background: var(--blue);
                    color: white;
                    border: none;
                }

            .action-icon {
                width: 30px;
                height: 30px;
                display: grid;
                place-items: center;
            }

            dialog::backdrop {
                background: rgba(0, 0, 0, 0.5);
            }

            .modal-input {
                width: 100%;
                padding: 10px;
                border-radius: 8px;
                border: 1px solid var(--border);
                margin-top: 5px;
            }

            @@media (max-width: 1100px) {
                .dashboard {
                    grid-template-columns: 1fr;
                }

                .sidebar {
                    display: none;
                }

                .kpi-grid {
                    grid-template-columns: repeat(2, 1fr);
                }

                .main-grid {
                    grid-template-columns: 1fr;
                }
            }
    </style>
</head>

<body>
    <div class="dashboard">
        <aside class="sidebar">
            <div class="logo">
                <div class="logo-icon">🌱</div>
                <div class="logo-text">Smart <span>Biodiversity</span></div>
            </div>
            <p class="menu-title">MENÚ</p>
            <nav class="menu">
                <a asp-controller="Administracion" asp-action="Index" class="menu-item">▦ Dashboard</a>
                <a asp-controller="Administracion" asp-action="InventarioEspecies" class="menu-item">🌿 Inventario Especies</a>
                <a href="#" class="menu-item">🔬 Taxonomía</a>
                <a href="#" class="menu-item">🗺️ Mapa Campus</a>
                <a href="#" class="menu-item">✅ Validaciones</a>
                <a asp-controller="Administracion" asp-action="Usuarios" class="menu-item">👥 Usuarios</a>
                <a asp-controller="Administracion" asp-action="Reportes" class="menu-item">📊 Reportes</a>
                <a href="#" class="menu-item">⚙️ Configuración</a>
            </nav>
            <div class="profile">
                <div class="avatar">A</div>
                <div class="profile-info"><strong>Perfil</strong><span>Administrador Principal</span></div>
            </div>
        </aside>

        <main class="main">
            <header class="topbar">
                <div class="topbar-brand">🌱 Smart Biodiversity</div>
                <div class="campus-select">Campus: El Olivo</div>
                <div class="topbar-actions">
                    <button class="icon-btn">🔔<span class="badge">3</span></button>
                    <button class="icon-btn">A</button>
                </div>
            </header>

            <section class="content">
                <div class="page-title">
                    <h1>Dashboard: Principal</h1>
                    <p>Campus: El Olivo</p>
                </div>

                <section class="kpi-grid">
                    <article class="kpi-card"><div class="kpi-icon">🌳</div><div><div class="kpi-title">Total Especies</div><div class="kpi-value" id="kpi-total">0</div></div></article>
                    <article class="kpi-card"><div class="kpi-icon">🔭</div><div><div class="kpi-title">Pendientes</div><div class="kpi-value" id="kpi-pendientes">0</div></div></article>
                    <article class="kpi-card"><div class="kpi-icon">🔬</div><div><div class="kpi-title">Nuevos</div><div class="kpi-value" id="kpi-nuevos">0</div></div></article>
                    <article class="kpi-card"><div class="kpi-icon">🌐</div><div><div class="kpi-title">Reportes</div><div class="kpi-value" id="kpi-reportes">8</div></div></article>
                </section>

                <section class="main-grid">
                    <article class="card">
                        <div class="card-header">
                            <div><h2>Inventario</h2><p>Registro de especies del campus</p></div>
                            <div class="inventory-tools"></div>
                        </div>
                        <div class="table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Nombre Común</th>
                                        <th>Nombre Científico</th>
                                        <th>Taxonomía</th>
                                        <th>Fisiología</th>
                                        <th>Ubicación</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody id="tabla-inventario">
                                    @if (Model != null)
                                    {
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@item.IdEspecie</td>
                                                <td>@item.NombreComun</td>
                                                <td>@item.NombreCientifico</td>
                                                <td>@item.Habitat</td>
                                                <td><span class="status">@item.EstadoEsp</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </article>

                    <aside class="card quick-actions">
                        <h2>Acciones rápidas</h2>
                        <div class="action-list">
                            <button class="action-btn primary" onclick="document.getElementById('modalRegistro').showModal()">
                                <span class="action-icon">+</span> Nuevo Registro
                            </button>
                            <button class="action-btn"><span class="action-icon">📊</span> Generar Reporte</button>
                            <button class="action-btn"><span class="action-icon">🗺️</span> Ver Mapa Campus</button>
                        </div>
                    </aside>
                </section>
            </section>
        </main>
    </div>

    <dialog id="modalRegistro" style="border-radius: var(--radius); border: 1px solid var(--border); padding: 24px; box-shadow: var(--shadow); width: 450px; background: var(--card);">
        <h2 style="margin-top: 0; color: var(--text);">Registrar Nueva Especie</h2>
        <form id="formRegistro">
            <div style="display: flex; flex-direction: column; gap: 15px;">
                <div>
                    <label style="font-size: 14px; color: var(--muted); font-weight: bold;">Nombre Común</label>
                    <input type="text" id="nombreComun" class="modal-input" required>
                </div>
                <div>
                    <label style="font-size: 14px; color: var(--muted); font-weight: bold;">Descripción</label>
                    <textarea id="descripcion" class="modal-input" required style="resize: vertical; min-height: 80px;"></textarea>
                </div>
                <div>
                    <label style="font-size: 14px; color: var(--muted); font-weight: bold;">Categoría ID</label>
                    <input type="number" id="categoriaId" class="modal-input" required>
                </div>
                <div id="errorMsg" style="color: var(--danger); font-size: 13px; display: none;"></div>
                <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 15px;">
                    <button type="button" onclick="document.getElementById('modalRegistro').close()" style="padding: 10px 15px; border-radius: 8px; border: 1px solid var(--border); background: white; cursor: pointer; color: var(--text);">Cancelar</button>
                    <button type="submit" style="background: var(--primary); color: white; border: none; padding: 10px 15px; border-radius: 8px; cursor: pointer; font-weight: bold;">Guardar Registro</button>
                </div>
            </div>
        </form>
    </dialog>

    <script>
            function actualizarKPIs() {
                const filas = document.querySelectorAll('#tabla-inventario tr');
                let total = 0;
                let pendientes = 0;
                let nuevos = 0;

                filas.forEach(fila => {
                    total++;
                    const estadoEl = fila.querySelector('.status');
                    const estado = estadoEl ? estadoEl.textContent.trim().toLowerCase() : '';
                    if (estado === 'pendiente') pendientes++;
                    if (estado === 'nuevo') nuevos++;
                });

                document.getElementById('kpi-total').textContent = total;
                document.getElementById('kpi-pendientes').textContent = pendientes;
                document.getElementById('kpi-nuevos').textContent = '+' + nuevos;
            }

            document.addEventListener('DOMContentLoaded', actualizarKPIs);

            document.getElementById('formRegistro').addEventListener('submit', function (e) {
                e.preventDefault();
                const errorBox = document.getElementById('errorMsg');
                errorBox.style.display = 'none';

                const formData = new FormData();
                formData.append('NombreComun', document.getElementById('nombreComun').value);
                formData.append('Descripcion', document.getElementById('descripcion').value);
                formData.append('CategoriaId', document.getElementById('categoriaId').value);

                fetch('/Especies/RegistrarAjax', {
                    method: 'POST',
                    body: formData
                })
                .then(async response => {
                    if (response.ok) {
                        document.getElementById('modalRegistro').close();
                        document.getElementById('formRegistro').reset();
                        location.reload();
                    } else {
                        const errorData = await response.text();
                        errorBox.textContent = `No se pudo registrar: ${errorData}`;
                        errorBox.style.display = 'block';
                    }
                })
                .catch(error => {
                    console.error('Error de red:', error);
                    errorBox.textContent = 'Error de conexión con el servidor.';
                    errorBox.style.display = 'block';
                });
            });
    </script>
</body>
</html>